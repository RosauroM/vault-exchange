generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  market_maker
  admin
}

enum KycStatus {
  none
  pending
  verified
}

enum VaultStatus {
  intake
  vaulted
  withdrawn
}

enum Grader {
  PSA
  BGS
  CGC
}

enum OfferingStatus {
  draft
  open
  closed
}

enum OrderSide {
  bid
  ask
}

enum OrderType {
  limit
  market
}

enum OrderStatus {
  open
  partial
  filled
  cancelled
}

enum AccountType {
  user
  house_treasury
  house_mm
  prize_pool
  stripe_clearing
}

enum LedgerReason {
  trade
  pack_award
  issuance
  treasury_seed
  adjustment
}

enum CashReason {
  deposit
  withdrawal
  trade
  pack_purchase
  fee
  adjustment
}

enum PackType {
  free_daily
  paid
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  displayName String?   @map("display_name")
  role        UserRole  @default(user)
  kycStatus   KycStatus @default(none) @map("kyc_status")
  createdAt   DateTime  @default(now()) @map("created_at")

  accounts         Account[]
  sessions         Session[]
  sharePositions   SharePosition[]
  shareLedgerEntries ShareLedgerEntry[]
  cashAccount      CashAccount?
  orders           Order[]
  buyTrades        Trade[]   @relation("BuyerTrades")
  sellTrades       Trade[]   @relation("SellerTrades")
  packPulls        PackPull[]
  dailyClaims      DailyClaim[]
  withdrawalRequests WithdrawalRequest[]

  @@map("users")
}

// Auth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Card {
  id                  String      @id @default(uuid())
  title               String
  setName             String      @map("set_name")
  year                Int
  grader              Grader
  grade               Decimal
  certNumber          String      @map("cert_number")
  imageUrl            String?     @map("image_url")
  vaultStatus         VaultStatus @default(intake) @map("vault_status")
  referencePriceCents Int         @map("reference_price_cents")
  sharesIssued        Int         @map("shares_issued")
  isTradeable         Boolean     @default(false) @map("is_tradeable")
  offeringId          String?     @map("offering_id")
  createdAt           DateTime    @default(now()) @map("created_at")

  offering         Offering?        @relation(fields: [offeringId], references: [id])
  sharePositions   SharePosition[]
  shareLedgerEntries ShareLedgerEntry[]
  orders           Order[]
  trades           Trade[]
  packPrizePool    PackPrizePool[]
  packPrizeWeights PackPrizeWeight[]
  mmConfig         MmConfig?

  @@map("cards")
}

model Offering {
  id          String         @id @default(uuid())
  totalShares Int            @map("total_shares")
  status      OfferingStatus @default(draft)
  createdAt   DateTime       @default(now()) @map("created_at")

  cards Card[]

  @@map("offerings")
}

model SharePosition {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  cardId  String @map("card_id")
  quantity Int
  locked   Int    @default(0)

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@map("share_positions")
}

model ShareLedgerEntry {
  id        String       @id @default(uuid())
  cardId    String       @map("card_id")
  userId    String       @map("user_id")
  delta     Int
  reason    LedgerReason
  refId     String?      @map("ref_id")
  createdAt DateTime     @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("share_ledger_entries")
}

model CashAccount {
  id           String      @id @default(uuid())
  userId       String?     @unique @map("user_id")
  accountType  AccountType @map("account_type")
  balanceCents BigInt      @default(0) @map("balance_cents")
  lockedCents  BigInt      @default(0) @map("locked_cents")

  user              User?              @relation(fields: [userId], references: [id])
  cashLedgerEntries CashLedgerEntry[]
  bids              Order[]            @relation("BidCashAccount")

  @@map("cash_accounts")
}

model CashLedgerEntry {
  id            String     @id @default(uuid())
  accountId     String     @map("account_id")
  deltaCents    BigInt     @map("delta_cents")
  reason        CashReason
  refId         String?    @map("ref_id")
  createdAt     DateTime   @default(now()) @map("created_at")

  account CashAccount @relation(fields: [accountId], references: [id])

  @@map("cash_ledger_entries")
}

model Order {
  id             String      @id @default(uuid())
  cardId         String      @map("card_id")
  userId         String      @map("user_id")
  side           OrderSide
  type           OrderType   @default(limit)
  priceCents     Int         @map("price_cents")
  quantity       Int
  filledQuantity Int         @default(0) @map("filled_quantity")
  status         OrderStatus @default(open)
  isHouse        Boolean     @default(false) @map("is_house")
  cashAccountId  String?     @map("cash_account_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  card        Card        @relation(fields: [cardId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  cashAccount CashAccount? @relation("BidCashAccount", fields: [cashAccountId], references: [id])
  bidTrades   Trade[]     @relation("BidOrder")
  askTrades   Trade[]     @relation("AskOrder")

  @@index([cardId, side, status, priceCents, createdAt])
  @@map("orders")
}

model Trade {
  id          String   @id @default(uuid())
  cardId      String   @map("card_id")
  bidOrderId  String   @map("bid_order_id")
  askOrderId  String   @map("ask_order_id")
  buyerId     String   @map("buyer_id")
  sellerId    String   @map("seller_id")
  priceCents  Int      @map("price_cents")
  quantity    Int
  createdAt   DateTime @default(now()) @map("created_at")

  card     Card  @relation(fields: [cardId], references: [id])
  bidOrder Order @relation("BidOrder", fields: [bidOrderId], references: [id])
  askOrder Order @relation("AskOrder", fields: [askOrderId], references: [id])
  buyer    User  @relation("BuyerTrades", fields: [buyerId], references: [id])
  seller   User  @relation("SellerTrades", fields: [sellerId], references: [id])

  @@index([cardId, createdAt])
  @@map("trades")
}

model Pack {
  id         String   @id @default(uuid())
  name       String
  type       PackType
  priceCents Int      @default(0) @map("price_cents")
  isActive   Boolean  @default(true) @map("is_active")

  packPrizeWeights PackPrizeWeight[]
  packPulls        PackPull[]
  dailyClaims      DailyClaim[]

  @@map("packs")
}

model PackPrizePool {
  id                String @id @default(uuid())
  cardId            String @map("card_id")
  quantityAvailable Int    @map("quantity_available")

  card Card @relation(fields: [cardId], references: [id])

  @@unique([cardId])
  @@map("pack_prize_pool")
}

model PackPrizeWeight {
  id           String  @id @default(uuid())
  packId       String  @map("pack_id")
  cardId       String  @map("card_id")
  sharesPerWin Int     @map("shares_per_win")
  weight       Decimal

  pack Pack @relation(fields: [packId], references: [id])
  card Card @relation(fields: [cardId], references: [id])

  @@map("pack_prize_weights")
}

model PackPull {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  packId         String   @map("pack_id")
  serverSeedHash String   @map("server_seed_hash")
  won            Boolean
  cardId         String?  @map("card_id")
  sharesAwarded  Int      @default(0) @map("shares_awarded")
  evCents        Int      @default(0) @map("ev_cents")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  pack Pack @relation(fields: [packId], references: [id])

  @@map("pack_pulls")
}

model DailyClaim {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  packId      String   @map("pack_id")
  claimedDate DateTime @map("claimed_date") @db.Date

  user User @relation(fields: [userId], references: [id])
  pack Pack @relation(fields: [packId], references: [id])

  @@unique([userId, packId, claimedDate])
  @@map("daily_claims")
}

model MmConfig {
  id                  String   @id @default(uuid())
  cardId              String   @unique @map("card_id")
  enabled             Boolean  @default(true)
  spreadBps           Int      @map("spread_bps")
  maxInventoryShares  Int      @map("max_inventory_shares")
  quoteSize           Int      @map("quote_size")
  updatedAt           DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id])

  @@map("mm_config")
}

model WithdrawalRequest {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  amountCents BigInt   @map("amount_cents")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawal_requests")
}
